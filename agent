#!/bin/bash
set -euo pipefail

readonly SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
readonly IMAGE_NAME="agent-host:latest"
readonly COMPOSE_FILE="$SCRIPT_DIR/docker-compose.yml"

# Directories whose contents are baked into the image
readonly BUILD_INPUTS=(
    "$SCRIPT_DIR/Dockerfile"
    "$SCRIPT_DIR/docker-compose.yml"
    "$SCRIPT_DIR/config"
    "$SCRIPT_DIR/scripts"
)

usage() {
    echo "Usage: agent <command>"
    echo ""
    echo "Commands:"
    echo "  up      Build (if needed) and start the agent host container"
    echo "  down    Stop and remove the agent host container"
    echo ""
    echo "The 'up' command automatically rebuilds the Docker image when"
    echo "Dockerfile, docker-compose.yml, config/, or scripts/ have changed"
    echo "since the last build."
}

# Returns 0 if the image needs to be (re)built, 1 otherwise.
needs_rebuild() {
    # If the image doesn't exist, we need to build
    if ! docker image inspect "$IMAGE_NAME" &>/dev/null; then
        echo "Image $IMAGE_NAME not found. Building..."
        return 0
    fi

    # Get image creation time as epoch seconds
    local image_created
    image_created="$(docker image inspect --format '{{.Created}}' "$IMAGE_NAME")"
    local image_epoch
    image_epoch="$(date -d "$image_created" +%s 2>/dev/null)" || {
        echo "Could not parse image timestamp. Rebuilding to be safe..."
        return 0
    }

    # Check if any build input is newer than the image
    for path in "${BUILD_INPUTS[@]}"; do
        if [ ! -e "$path" ]; then
            continue
        fi

        # Find the newest file under this path
        local newest_epoch
        newest_epoch="$(find "$path" -type f -printf '%T@\n' 2>/dev/null | sort -rn | head -1)"
        if [ -z "$newest_epoch" ]; then
            continue
        fi
        # Truncate to integer seconds
        newest_epoch="${newest_epoch%%.*}"

        if [ "$newest_epoch" -gt "$image_epoch" ]; then
            echo "Changes detected in $path. Rebuilding..."
            return 0
        fi
    done

    return 1
}

cmd_up() {
    cd "$SCRIPT_DIR"

    if needs_rebuild; then
        echo "Building image..."
        docker-compose build
        echo ""
    else
        echo "Image is up to date."
    fi

    echo "Starting container..."
    docker-compose up -d
    echo "Agent host is running."
}

cmd_down() {
    cd "$SCRIPT_DIR"
    echo "Stopping container..."
    docker-compose down
    echo "Agent host stopped."
}

# --- Main ---

if [ $# -lt 1 ]; then
    usage
    exit 1
fi

case "$1" in
    up)
        cmd_up
        ;;
    down)
        cmd_down
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        echo "Unknown command: $1"
        echo ""
        usage
        exit 1
        ;;
esac
