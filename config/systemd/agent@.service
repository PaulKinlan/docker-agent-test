[Unit]
Description=Agent for user %i
After=basic.target

[Service]
Type=simple
User=%i
Group=%i
WorkingDirectory=/home/%i
ExecStart=/usr/local/bin/run-agent.sh
Restart=always
RestartSec=5

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=agent-%i

# ── Security hardening ──────────────────────────────────────
# Many systemd security and resource directives fail silently in Docker
# containers on older kernels (e.g., 4.4.x), causing services to go
# straight to inactive (dead) with no journal output. The seccomp-based
# directives (RestrictAddressFamilies, RestrictSUIDSGID) and cgroup-based
# directives (MemoryMax, CPUQuota) are the primary offenders. Mount
# namespace directives (ProtectSystem, PrivateTmp) can also fail depending
# on the Docker storage driver and kernel version.
#
# The Docker container boundary already provides process and filesystem
# isolation. Agents still run as unprivileged users with no sudo access.
#
# To re-enable on newer kernels (5.x+) or outside Docker, uncomment:
# NoNewPrivileges=true
# ProtectSystem=full
# PrivateTmp=true
# CapabilityBoundingSet=
# AmbientCapabilities=
# RestrictSUIDSGID=true
# RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
# ProtectKernelTunables=true
# ProtectKernelModules=true
# ProtectControlGroups=true
# ProtectKernelLogs=true
# RestrictNamespaces=true
# MemoryMax=512M
# CPUQuota=50%

[Install]
WantedBy=multi-user.target
